

class Solution:
    def canPlaceFlowers(self, flowerbed: List[int], n: int) -> bool:
        l=flowerbed
        ct=0
        for i in range(len(l)):
            if l[i] == 0 and (i == 0 or l[i-1] == 0) and (i == len(l)-1 or l[i+1] == 0):
                l[i] = 1
                ct += 1
        return ct >= n
        
   

        
        
