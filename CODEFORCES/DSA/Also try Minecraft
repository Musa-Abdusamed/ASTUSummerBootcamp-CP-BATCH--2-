
n, m = map(int, input().split())
a = [0] + list(map(int, input().split()))

right = [0] * (n + 1)
for i in range(1, n):
    right[i + 1] = right[i] + max(0, a[i] - a[i + 1])

left = [0] * (n + 1)
for i in range(n - 1, 0, -1):
    left[i] = left[i + 1] + max(0, a[i + 1] - a[i])

for _ in range(m):
    s, t = map(int, input().split())
    if s < t:
        print(right[t] - right[s])
    else:
        print(left[t] - left[s])
